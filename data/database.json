  "syllabusModuleSchema": {
    "_note": "This describes the shape of each day/module object as used in the admin panel and localStorage.",
    "fields": {
      "id": "string — unique ID generated at creation time (Date.now() + Math.random())",
      "day": "string — e.g. 'Day 1'",
      "title": "string — module title, e.g. 'Introduction to Vector Grids'",
      "note": {
        "name": "string — original filename of the uploaded PDF/image",
        "dataUrl": "string — base64 encoded data URL of the file"
      },
      "tool": {
        "name": "string — original filename of the uploaded ZIP/image/etc.",
        "dataUrl": "string — base64 encoded data URL of the file"
      },
      "zoomLink": "string — URL of the Zoom recording, e.g. https://zoom.us/rec/play/..."
    }
  },

