  "portfolioItemSchema": {
    "_note": "Shape of each item stored in localStorage under 'academyPortfolioData'.",
    "fields": {
      "id": "string — Date.now().toString()",
      "title": "string — project title",
      "category": "string — one of the portfolioCategories[].id values",
      "image": "string — base64 data URL of the project image",
      "websiteLink": "string — external URL (only for web-design category, otherwise empty string)"
    }
  },

  "studentSchema": {
    "_note": "Shape of the student profile object stored in localStorage under 'academyStudentProfile'.",
    "fields": {
      "email": "string — student email (acts as unique identifier)",
      "phone": "string — student phone number",
      "password": "string — hashed or plain password set on registration",
      "course": "string — selected course name from the course list",
      "createdAt": "ISO-8601 datetime string — e.g. 2026-07-08T17:00:00.000Z"
    }
  },

  "purchaseRequestSchema": {
    "_note": "Shape of each purchase/payment request stored in localStorage under 'academyPurchases'.",
    "fields": {
      "id": "string — 'purchase_' + Date.now()",
      "studentEmail": "string",
      "studentPhone": "string",
      "courseName": "string",
      "coursePrice": "string",
      "courseDescription": "string",
      "bankSlip": "string — 'Uploaded' (placeholder; actual file not stored yet)",
      "status": "string — 'pending' | 'approved' | 'rejected'",
      "requestedAt": "ISO-8601 datetime string"
    }
  },

  "approvedAccessSchema": {
    "_note": "Shape of each approved access record stored in localStorage under 'academyApprovedAccess'.",
    "fields": {
      "studentEmail": "string",
      "courseName": "string",
      "approvedAt": "ISO-8601 datetime string"
    }
  },

  "admin": {
    "localStorageKeys": {
      "studentProfile": "academyStudentProfile",
      "purchases": "academyPurchases",
